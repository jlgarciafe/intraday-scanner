# Copy to .env for local testing — never commit this file

# Telegram (same bot as job hunt agent, or create a new one)
TELEGRAM_BOT_TOKEN=your_bot_token
TELEGRAM_CHAT_ID=your_chat_id

# Scanner settings (can also be set via workflow_dispatch inputs)
MARKET_CONTEXT=all        # all / us / uk / de / jp / eu
MIN_MOVE_PCT=5.0          # minimum target move %
DRY_RUN=false             # true = no Telegram, just logs
